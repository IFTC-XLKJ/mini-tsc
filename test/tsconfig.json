{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "lib": ["ES2022"],
    "types": [],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rootDir": "..",
    "baseUrl": ".."
  },
  "include": [
    "./**/*.ts",
    "../types/**/*.d.ts"
  ],
  "exclude": [
    "../src",
    "../node_modules",
    "../dist",
    "../runtime",
    "../out",
    "../out_*",
    "./command.ts",
    "./fixtures/**"
  ]
}
